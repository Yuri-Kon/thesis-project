sequenceDiagram
  autonumber
  participant E as ExecutorAgent
  participant P as PlannerAgent
  participant KG as ProteinToolKG
  participant A as ToolAdapter(X)
  participant S as SafetyAgent
  participant D as DataStore

  Note over E: 执行某步Sk
  E->>A: run(inputs)
  alt 成功
    A-->>E: outputs
    E->>S: safety_check(step_outputs)
    S-->>E: ok|warn
    E->>D: log(step=S_k, satus=OK, warn?)
  else 失败(Exception/TImeout/Bad IO)
    A-->>E: error(detail)
    E->>D: log(step=S_k, status=FAIL, detail)
    E->>E: retry(backoff: 1s->3s, max=2)
    alt 重试仍失败
      E-->>P:request_local_fix(context: inputs, error)
      P->>KG: query(alternatives for capability_fo(X))
      KG-->>P: candidates(sorted by cost/safeyt/io-compact)
      P-->>E: patch_step(S_k->X') + params_delta(threshold, batch, cutoff)
      E->>D: log(step=S_k, action=REPLACE_TOOL, new=X')
      E->>A: run'(inputs')
      A-->>E: outputs'
      E->>S: safety_check(outputs')
      alt block
        E-->>P: request_replan(upstream change?)
        P-->>E: subplan_replace(S_{k-1...k+1})
      else ok|warn
        E->>D: log(step=S_k', status=OK, flags)
      end
    else 重试成功
      E->>D: log(step=S_k, status=OK_after_retry)
    end
  end
