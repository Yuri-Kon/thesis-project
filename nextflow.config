/*
 * Nextflow 配置文件
 *
 * 定义执行环境和容器配置
 */

// 默认参数
params {
    output_dir = "output"
}

// Profile 配置
profiles {
    // Docker profile（默认）
    docker {
        docker.enabled = true
        docker.runOptions = '--gpus all'
    }

    // Podman profile（Fedora 开发环境）
    podman {
        podman.enabled = true
        podman.runOptions = '--device nvidia.com/gpu=all'
    }

    // 测试 profile（不使用容器）
    test {
        docker.enabled = false
        podman.enabled = false
    }

    // 标准 profile（别名）
    standard {
        docker.enabled = false
        podman.enabled = false
    }
}

// 工作目录配置
workDir = 'work'

// 报告配置
report {
    enabled = false
}

timeline {
    enabled = false
}

trace {
    enabled = false
}
